generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model AppData {
  id        String   @id @default(cuid())
  key       String   @unique
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Seo {
  key         String   @id @default("main")
  title       String
  description String
  robotsTxt   String?
  sitemapXml  String?
  updatedAt   DateTime @updatedAt
}

model ProjectCategory {
  id        String    @id @default(cuid())
  title     String    @unique
  sortOrder Int       @default(0)
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id          String          @id @default(cuid())
  title       String
  description String
  textBlock1  String?
  textBlock2  String?
  videoUrl    String?
  categoryId  String
  category    ProjectCategory @relation(fields: [categoryId], references: [id])
  sortOrder   Int             @default(0)
  images      Json            @default("[]")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProductCategory {
  id        String    @id @default(cuid())
  title     String    @unique
  slug      String    @unique
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id                  String          @id @default(cuid())
  title               String
  slug                String          @unique
  description         String
  metaTitle           String?
  metaDescription     String?
  materials           String?
  stove               String?
  interiorHtml        String?
  characteristicsHtml String?
  kitHtml             String?
  isPopular           Boolean         @default(false)
  categoryId          String
  category            ProductCategory @relation(fields: [categoryId], references: [id])
  sortOrder           Int             @default(0)
  sizes               ProductSize[]
  images              Json            @default("[]")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model ProductSize {
  id        String   @id @default(cuid())
  label     String
  value     String
  price     Int
  code      String
  sortOrder Int      @default(0)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
